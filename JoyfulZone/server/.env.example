# 服务端口（本机调试默认 3000）
PORT=3000

# 阿里云 IoT 区域与产品（与门锁固件 app_config.h 中 ProductKey 一致）
ALIYUN_IOT_REGION=cn-shanghai
ALIYUN_IOT_PRODUCT_KEY=k1vtgud0XCS

# 门锁终端设备名（固件连 1111，仅作标识）
ALIYUN_LOCK_DEVICE_NAME=1111

# 后端服务器设备（控制台单独创建的设备，MQTT 客户端身份）
# 不要提交到 Git；复制本文件为 .env 后填写
ALIYUN_SERVER_DEVICE_NAME=
ALIYUN_SERVER_DEVICE_SECRET=

# 阿里云 AccessKey（仅后端拉取物模型 3 个月历史用，勿提交 Git）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 物联网平台「实例概览」里的实例 ID（新版公共实例必填，形如 iot-cn-xxxxxxxx）
ALIYUN_IOT_INSTANCE_ID=
